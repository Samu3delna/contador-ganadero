{
  "name": "backend",
  "version": "1.0.0",
  "description": "Backend API para ContadorGanadero — contabilidad, inventario y facturación para productores agropecuarios del REA",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "migrate:tenant": "node scripts/migrateTenant.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "axios": "^1.18.1",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.80.11",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dompurify": "^3.4.8",
    "dotenv": "^16.4.2",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-rate-limit": "^7.5.0",
    "fast-xml-parser": "^5.2.0",
    "helmet": "^8.1.0",
    "imapflow": "^1.3.5",
    "ioredis": "^5.11.1",
    "jsdom": "^29.1.1",
    "jsonwebtoken": "^9.0.2",
    "mailparser": "^3.7.2",
    "mongoose": "^8.9.5",
    "morgan": "^1.10.1",
    "multer": "^1.4.5-lts.2",
    "node-forge": "^1.4.0",
    "nodemailer": "^6.10.1",
    "openai": "^4.35.0",
    "pdf-parse": "^1.1.1",
    "pdfkit": "^0.19.1",
    "stripe": "^22.3.2",
    "tiktoken": "^1.0.22",
    "uuid": "^14.0.0",
    "xml-crypto": "^6.1.2"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/preset-env": "^7.29.7",
    "@eslint/js": "^10.0.1",
    "@types/jest": "^29.5.12",
    "babel-jest": "^30.4.1",
    "globals": "^17.6.0",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^10.1.4",
    "nodemon": "^3.1.14",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "setupFilesAfterEnv": [
      "<rootDir>/jest.setup.js"
    ],
    "testMatch": [
      "**/__tests__/**/*.js",
      "**/*.test.js"
    ],
    "collectCoverageFrom": [
      "services/**/*.js",
      "utils/**/*.js",
      "controllers/**/*.js",
      "models/**/*.js"
    ],
    "coverageDirectory": "coverage",
    "verbose": true,
    "transform": {
      "^.+\\.js$": "babel-jest"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!(uuid)/)"
    ]
  }
}
