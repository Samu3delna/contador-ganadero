{
  "name": "backend",
  "version": "1.0.0",
  "description": "Backend API para ContadorGanadero — contabilidad, inventario y facturación para productores agropecuarios del REA",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^16.4.2",
    "express": "^4.18.2",
    "express-rate-limit": "^7.5.0",
    "fast-xml-parser": "^5.2.0",
    "helmet": "^8.1.0",
    "imapflow": "^1.3.5",
    "jsonwebtoken": "^9.0.2",
    "mailparser": "^3.7.2",
    "mongoose": "^8.9.5",
    "morgan": "^1.10.1",
    "multer": "^1.4.5-lts.2",
    "nodemailer": "^6.10.1",
    "openai": "^4.35.0",
    "pdf-parse": "^1.1.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.14",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.12",
    "supertest": "^7.0.0",
    "mongodb-memory-server": "^10.1.4"
  },
  "jest": {
    "testEnvironment": "node",
    "setupFilesAfterEnv": ["<rootDir>/jest.setup.js"],
    "testMatch": ["**/__tests__/**/*.js", "**/*.test.js"],
    "collectCoverageFrom": [
      "services/**/*.js",
      "utils/**/*.js",
      "controllers/**/*.js",
      "models/**/*.js"
    ],
    "coverageDirectory": "coverage",
    "verbose": true
  }
}
