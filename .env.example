# ===== Base de Datos =====
MONGODB_URI=mongodb+srv://tu_usuario:tu_password@cluster0.ejemplo.mongodb.net/contador_ganadero

# ===== Servidor =====
PORT=5000
NODE_ENV=development
JWT_SECRET=secreto_jwt_muy_seguro_y_largo_minimo_64_caracteres_hex
JWT_EXPIRE=1h

# ===== CORS (URL del frontend en producción — Vercel) =====
FRONTEND_URL=http://localhost:3000

# ===== Email IMAP =====
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=tu_correo@gmail.com
IMAP_PASSWORD=tu_contraseña_de_aplicacion
IMAP_TLS=true

# ===== IA (NVIDIA NIM API) =====
AI_API_KEY=tu_api_key_de_nvidia
AI_MODEL=nvidia/nemotron-3-ultra-550b-a55b
# AI_BASE_URL=https://integrate.api.nvidia.com/v1

# ===== Cifrado ==========
EMAIL_ENC_KEY=clave_hex_de_64_caracteres_para_aes256

# ===== Frontend =====
VITE_API_URL=http://localhost:5000/api

# ===== Hacienda CR (Facturacion Electronica v4.4) =====
# Ambiente: local (mock, no llama a Hacienda) | sandbox | produccion
HACIENDA_AMBIENTE=local
# Ruta al archivo .p12 (llave criptografica del emisor / sus certificados)
HACIENDA_P12_PATH=./certificados/emisor.p12
# PIN de 14 caracteres de la llave criptografica
HACIENDA_PIN=
# Usuario del API en formato cpf-<tipo>-<identificacion>@comprobanteselectronicos.go.cr
HACIENDA_USUARIO=
# Password del API del emisor
HACIENDA_PASSWORD=
# Worker embedded en server.js (modo dev). En produccion usar worker.js como Background Worker
HACIENDA_WORKER_EMBEDDED=true
HACIENDA_WORKER_INTERVAL_MS=15000
